# Required for Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-with-a-random-32-char-string

# The base URL of the app (used by Better Auth for callbacks/redirects)
BETTER_AUTH_URL=http://localhost:3000

# Google OAuth — create credentials at https://console.cloud.google.com/apis/credentials
# Set Authorized redirect URI to: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth — create an OAuth App at https://github.com/settings/developers
# Set Authorization callback URL to: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Anthropic API — required for AI content generation features
# Get your key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
